# Commotion skills — direct-HTTP config. Copy to .env and fill in the secret.
# The skills call the dev3 backend directly via Kong using these (no MCP server).
# Load before running:  set -a; . ./.env; set +a

# --- secret (required) — provide your own Kong api-key; never commit it ---
KONG_API_KEY=

# --- non-secret (defaults shown; mirror commotion-mcp/server/configuration/settings.yaml) ---
KONG_BACKEND_URL=https://apigw.dev3.gocommotion.com
KONG_API_KEY_HEADER=apikey
KONG_ROUTE_SELECTOR=demo_workspace
