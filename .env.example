# Commotion skills — direct-HTTP config. This .env is OPTIONAL: the skill prompts for KONG_API_KEY
# at session start (Step 0) and writes it to a session-only file ($TMPDIR/commotion-mcp/session.env),
# so no committed secret is required. Use .env only as a local convenience for repeated runs —
# copy to .env, fill in the secret, and load before running:  set -a; . ./.env; set +a
# An exported KONG_API_KEY / this .env takes precedence over the session file. Never commit .env.

# --- secret (optional here — provide via Step 0 or your shell; never commit it) ---
KONG_API_KEY=

# --- non-secret (defaults shown; mirror commotion-mcp/server/configuration/settings.yaml) ---
KONG_BACKEND_URL=https://apigw.dev3.gocommotion.com
KONG_API_KEY_HEADER=apikey
KONG_ROUTE_SELECTOR=demo_workspace
